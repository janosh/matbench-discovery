# package install
*.egg-info
dist
build
.coverage*

# cache
__pycache__
.cache
.svelte-kit

# datasets
*.pth.tar
*.json.gz
*.json.bz2
*.csv.*
*.pkl.gz
data/**/raw
data/**/tsne
!data/mp/2023-02-07-mp-elemental-reference-entries.json.gz
# committed data-only figure payloads (written by matbench_discovery.figs): static ones
# as gzipped <name>.json.gz (re-included below); multi-model ones as line-delimited
# <name>.jsonl, which the *.json.gz ignore above doesn't match (so they stay tracked)
!site/src/figs/*.json.gz
data/**/*.extxyz*
data/**/*.json*
data/**/*.zip*
data/wbm/*symprec=*.csv*
!data/**/*umap-projections.csv.bz2

# model checkpoints and prediction files
models/**/*.model
models/**/*.pt
models/**/*.tgz
models/**/*.csv*
models/**/*.json*

# WIP model submissions
models/_*

# auto-generated docs
site/src/routes/api/*.md

# large files
data/*-models-geo-opt-analysis-symprec=*.csv.gz
.cursor

# lock files
uv.lock

# paper figs
paper/figs/
